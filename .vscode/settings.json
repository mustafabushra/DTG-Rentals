{
  "typescript.tsserver.maxTsServerMemory": 3072,
  "typescript.disableAutomaticTypeAcquisition": false,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/node_modules/**": true,
    "**/.expo/**": true,
    "**/dist/**": true,
    "**/.firebase/**": true,
    "**/android/**": true,
    "**/ios/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.expo": true,
    "**/dist": true
  },
  "typescript.preferences.includePackageJsonAutoImports": "off",
  "editor.formatOnSave": false
}
