rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Super admin — bypasses all rules ─────────────────────────────────────
    function isSuperAdmin() {
      return request.auth != null &&
             request.auth.uid == 'z70x4OkpfZcOuYjCbihlOmYx5MB2';
    }

    // ── Helper functions ──────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return getUserData().role;
    }

    // توافق مع البيانات القديمة: مستندات أُنشئت قبل تعدد المؤسسات قد تنقصها هذه الحقول.
    // غياب orgId يعني المؤسسة الأصلية 'main'؛ غياب status يعني حساباً نشطاً.
    function userOrg() {
      return getUserData().get('orgId', 'main');
    }

    function isActive() {
      return getUserData().get('status', 'active') in ['active', 'pending'];
    }

    // التحقق أن مستند المستخدم المطلوب إنشاؤه يطابق دعوة كود معلّقة (لاستبدال الكود client-side).
    // يمنع انتحال مؤسسة/دور/مالك: كلها يجب أن تساوي ما حدّده المدير في الدعوة.
    function inviteData(code) {
      return get(/databases/$(database)/documents/inviteCodes/$(code)).data;
    }
    function inviteMatches(data) {
      return exists(/databases/$(database)/documents/inviteCodes/$(data.inviteCode))
        && inviteData(data.inviteCode).status == 'pending'
        && inviteData(data.inviteCode).orgId == data.orgId
        && inviteData(data.inviteCode).role == data.role
        && inviteData(data.inviteCode).get('ownerId', '') == data.get('ownerId', '');
    }

    function isAdmin() {
      return isSignedIn() && isActive() &&
             userRole() in ['admin', 'مدير عام', 'مدير النظام'];
    }

    function canWrite() {
      return isSignedIn() && isActive() &&
             userRole() in ['admin', 'مدير عام', 'مدير النظام', 'manager', 'مدير', 'owner', 'مالك'];
    }

    function canRead() {
      return isSignedIn() && isActive();
    }

    function isOwnerRole() {
      return isSignedIn() && isActive() &&
             userRole() in ['owner', 'مالك'];
    }

    function ownerLinkedId() {
      return getUserData().ownerId;
    }

    function isSameOrg(orgId) {
      return userOrg() == orgId;
    }

    function isManager() {
      return isSignedIn() && isActive() &&
             userRole() in ['manager', 'مدير'];
    }

    function isManagerOrAdmin() {
      return isAdmin() || isManager();
    }

    // المجموعات الحساسة التي تخضع لعزل المالك (قراءة/كتابة محصورة بـ ownerId)
    function isOwnerScopedCol(col) {
      return col in ['properties', 'units', 'contracts', 'payments', 'maintenance', 'bookings'];
    }

    // مراجع مشتركة يقرؤها أي عضو نشط في المؤسسة (المالك التابع أيضاً)
    function isSharedReadCol(col) {
      return col in ['cities', 'settings', 'calendarEvents', 'photos', 'tenants', 'attachments'];
    }

    // مراجع مشتركة يجوز للمالك التابع الكتابة فيها
    function isOwnerWritableSharedCol(col) {
      return col in ['calendarEvents', 'photos', 'tenants'];
    }

    function validString(val, maxLen) {
      return val is string && val.size() > 0 && val.size() <= maxLen;
    }

    function validOptionalString(val, maxLen) {
      return val == null || (val is string && val.size() <= maxLen);
    }

    function validPositiveInt(val, maxVal) {
      return val is int && val > 0 && val <= maxVal;
    }

    // ── User profiles ─────────────────────────────────────────────────────────
    // الأمان: لا يستطيع المستخدم الانضمام إلى مؤسسة غيره ولا تصعيد دوره/حالته.
    match /users/{uid} {
      // قراءة: مستندك أنت، أو مدير يقرأ مستخدمي مؤسسته فقط.
      allow read: if isSuperAdmin()
        || (isSignedIn() && request.auth.uid == uid)
        || (isSignedIn() && isAdmin() && resource.data.get('orgId', 'main') == userOrg());

      // تسجيل ذاتي: مستندك أنت فقط، وبمؤسسة جديدة خاصة بك (orgId == uid)
      // — يمنع وضع orgId='main' للانضمام إلى مؤسسة قائمة والاطلاع على بياناتها.
      // أو: مدير يُنشئ مستخدماً داخل مؤسسته هو (مثل دعوة مالك تابع).
      // أو: استبدال كود دعوة (client-side، بلا Cloud Function) — المستخدم ينشئ مستنده
      //     بمؤسسة/دور/ownerId يجب أن تطابق دعوة pending موجودة في inviteCodes؛ فلا يقدر
      //     ينتحل مؤسسة أو يصعّد دوره. الكود هو "السر" الذي يصرّح بالانضمام.
      allow create: if isSuperAdmin()
        || (isSignedIn() && request.auth.uid == uid
            && request.resource.data.orgId == uid)
        || (isSignedIn() && isAdmin()
            && request.resource.data.orgId == userOrg())
        || (isSignedIn() && request.auth.uid == uid
            && inviteMatches(request.resource.data));

      // تحديث ذاتي: يجوز تعديل الملف الشخصي فقط — لا role/orgId/status/ownerId.
      // المدير يُحدّث مستخدمي مؤسسته فقط، ولا ينقلهم إلى مؤسسة أخرى.
      allow update: if isSuperAdmin()
        || (isSignedIn() && request.auth.uid == uid
            && request.resource.data.get('orgId',   '') == resource.data.get('orgId',   '')
            && request.resource.data.get('role',    '') == resource.data.get('role',    '')
            && request.resource.data.get('status',  '') == resource.data.get('status',  '')
            && request.resource.data.get('ownerId', '') == resource.data.get('ownerId', ''))
        || (isSignedIn() && isAdmin()
            && resource.data.get('orgId', 'main') == userOrg()
            && request.resource.data.get('orgId', 'main') == userOrg());

      allow delete: if isSuperAdmin();
    }

    // ── Org data ──────────────────────────────────────────────────────────────
    // المدير/المالك المستقل (admin) والمدير التنفيذي (manager): وصول كامل لمؤسستهم.
    // المالك التابع (owner): قراءة/كتابة محصورة بسجلاته (ownerId) على المجموعات الحساسة،
    // ووصول للمراجع المشتركة فقط. ملاحظة: قواعد Firestore تتحد (OR) عبر المسارات المطابقة،
    // لذا نستخدم قوائم بيضاء صريحة حتى لا يتسرّب وصول auditLogs/managedUsers عبر هذه القاعدة العامة.
    match /orgs/{orgId}/{collection}/{docId} {

      allow read: if isSuperAdmin() || (canRead() && isSameOrg(orgId) && (
        isManagerOrAdmin() ||
        (collection == 'owners' && docId == ownerLinkedId()) ||
        (isOwnerScopedCol(collection) && resource.data.ownerId == ownerLinkedId()) ||
        isSharedReadCol(collection)
      ));

      allow create: if isSuperAdmin() || (isSameOrg(orgId)
        && validateDoc(collection, request.resource.data)
        && (
          isManagerOrAdmin() ||
          (isOwnerRole() && isOwnerScopedCol(collection)
             && request.resource.data.ownerId == ownerLinkedId()) ||
          (isOwnerRole() && collection == 'attachments'
             && request.resource.data.ownerContext == ownerLinkedId()) ||
          (isOwnerRole() && isOwnerWritableSharedCol(collection))
        ));

      allow update: if isSuperAdmin() || (isSameOrg(orgId)
        && validateDoc(collection, request.resource.data)
        && (
          isManagerOrAdmin() ||
          (isOwnerRole() && isOwnerScopedCol(collection)
             && resource.data.ownerId == ownerLinkedId()
             && request.resource.data.ownerId == ownerLinkedId()) ||
          (isOwnerRole() && collection == 'attachments'
             && resource.data.ownerContext == ownerLinkedId()) ||
          (isOwnerRole() && isOwnerWritableSharedCol(collection))
        ));

      allow delete: if isSuperAdmin() || (isSameOrg(orgId) && (
        isAdmin() ||
        (isOwnerRole() && collection == 'attachments'
           && resource.data.ownerContext == ownerLinkedId())
      ));
    }

    // ── سجل الإجراءات ────────────────────────────────────────────────────────
    match /orgs/{orgId}/auditLogs/{logId} {
      allow read:         if isSuperAdmin() || (isAdmin() && isSameOrg(orgId));
      allow create:       if isSuperAdmin() || (canRead() && isSameOrg(orgId));
      allow update,delete: if isSuperAdmin();
    }

    // ── managedUsers sub-collection ───────────────────────────────────────────
    match /orgs/{orgId}/managedUsers/{uid} {
      allow read:  if isSuperAdmin() || (canRead()  && isSameOrg(orgId));
      allow write: if isSuperAdmin() || (isAdmin()  && isSameOrg(orgId));
      // المستبدِل لكود الدعوة يضيف سجله الذاتي بعد إنشاء مستند users (الذي ضبط orgId=هذه المؤسسة)
      allow create: if request.auth.uid == uid && isSameOrg(orgId);
    }

    // ── أكواد الدعوة (top-level) ───────────────────────────────────────────────
    // استبدال client-side بلا Cloud Function. get: أي مسجّل دخول يعرف الكود بالضبط
    // (لا list للعموم → لا تعداد). list: مدير على مؤسسته فقط (لعرض الدعوات المعلّقة).
    match /inviteCodes/{code} {
      allow get:  if isSignedIn();
      allow list: if isSuperAdmin() || (isAdmin() && resource.data.orgId == userOrg());
      allow create: if isSuperAdmin()
        || (isAdmin() && request.resource.data.orgId == userOrg());
      // استهلاك الكود: أي مسجّل دخول يحوّل pending→used (تغيير الحالة فقط)؛ أو المدير يلغي/يعدّل.
      allow update: if isSuperAdmin()
        || (isAdmin() && resource.data.orgId == userOrg())
        || (resource.data.status == 'pending'
            && request.resource.data.status == 'used'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'usedBy', 'usedAt']));
      allow delete: if isSuperAdmin() || (isAdmin() && resource.data.orgId == userOrg());
    }

    // ── سجل تحديثات التطبيق (changelog عام، top-level) ─────────────────────────
    // feed داخلي مشترك لكل المؤسسات: يقرؤه أي مستخدم مسجّل (live)، ويكتبه المطوّر فقط.
    match /appUpdates/{updateId} {
      allow read:  if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // ── Per-document validation ───────────────────────────────────────────────
    function validateDoc(col, data) {
      return col == 'properties'  ? validateProperty(data)
           : col == 'owners'      ? validateOwner(data)
           : col == 'tenants'     ? validateTenant(data)
           : col == 'contracts'   ? validateContract(data)
           : col == 'units'       ? validateUnit(data)
           : col == 'payments'    ? validatePayment(data)
           : col == 'maintenance' ? validateMaintenance(data)
           : col == 'bookings'    ? validateBooking(data)
           : true; // allow other collections without strict validation
    }

    function validateBooking(data) {
      return validString(data.unitId, 100) &&
             validString(data.propertyId, 100) &&
             validString(data.guestName, 200) &&
             validString(data.checkIn, 20) &&
             validString(data.checkOut, 20) &&
             data.checkOut > data.checkIn &&
             data.nightlyRate is number && data.nightlyRate > 0 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['confirmed', 'cancelled'];
    }

    function validateProperty(data) {
      return validString(data.name, 200) &&
             validOptionalString(data.location, 500) &&
             validOptionalString(data.description, 1000);
    }

    function validateOwner(data) {
      return validString(data.name, 200) &&
             validString(data.phone, 20) &&
             validOptionalString(data.email, 254) &&
             validOptionalString(data.nationalId, 50) &&
             validOptionalString(data.iban, 50);
    }

    function validateTenant(data) {
      return validString(data.name, 200) &&
             validString(data.phone, 20) &&
             validOptionalString(data.email, 254) &&
             validOptionalString(data.nationalId, 50) &&
             validOptionalString(data.nationality, 50);
    }

    function validateContract(data) {
      return validString(data.tenantId, 100) &&
             validString(data.unitId, 100) &&
             validString(data.startDate, 20) &&
             validString(data.endDate, 20) &&
             data.annualValue is number && data.annualValue > 0;
    }

    function validateUnit(data) {
      return validString(data.propertyId, 100) &&
             validString(data.number, 50);
    }

    function validatePayment(data) {
      return validString(data.contractId, 100) &&
             data.amount is number && data.amount > 0 &&
             data.status in ['pending','paid','overdue','cancelled'];
    }

    function validateMaintenance(data) {
      return validString(data.propertyId, 100) &&
             validString(data.title, 200) &&
             validOptionalString(data.priority, 50);
    }
  }
}
